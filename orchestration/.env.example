# Copy this file to .env at the repo root (which is already in .gitignore)
# and fill in real values. Then `python orchestration/run_catas.py` will
# auto-switch to LIVE mode.

# ----- Lyzr Agent API -----
# Obtain from Lyzr Studio -> Settings -> API Keys.
LYZR_API_KEY=

# Each agent's ID is in its URL in Lyzr Studio (studio.lyzr.ai/agent/<ID>).
LYZR_TREASURY_AGENT_ID=
LYZR_COMPLIANCE_AGENT_ID=

# Optional overrides — defaults usually fine.
# LYZR_USER_ID=catas-orchestrator
# LYZR_BASE_URL=https://agent-prod.studio.lyzr.ai

# ----- MLRO alert delivery (used by trigger_mlro_alert skill) -----
# Set at least one of these to deliver remote alerts. Without them, the
# skill still writes a local audit copy to logs/mlro_alerts.jsonl.

# Webhook (Slack / Teams / PagerDuty / Lambda function URL)
# ALERT_WEBHOOK_URL=

# AWS SES email
# ALERT_SENDER=mlro-alerts@yourdomain.example
# ALERT_RECIPIENT=mlro@yourdomain.example
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ----- CATAS local paths (rarely needed) -----
# CATAS_DATA_DIR=/abs/path/to/data
# CATAS_LOG_DIR=/abs/path/to/logs
